# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is git-ignored.

# --- Firebase (required) -----------------------------------------------------
# Get these from your Firebase project settings:
#   https://console.firebase.google.com  ->  Project settings  ->  Your apps  ->  Web app
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# --- Gemini (optional) -------------------------------------------------------
# The AI Coach uses a bring-your-own-key model: users paste their key in the
# app's Settings panel and it's stored in browser localStorage. This env var
# is only useful as a developer default and is NOT required to run the app.
# VITE_GEMINI_API_KEY=""
